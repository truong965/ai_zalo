# Server Configuration
PORT=3001
NODE_ENV=development

# Main App Internal API (zalo_backend)
MAIN_APP_INTERNAL_URL=http://localhost:3000
MAIN_APP_INTERNAL_API_KEY=your_shared_internal_secret_key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# ai_zalo PostgreSQL database
AI_DATABASE_URL=postgresql://postgres:dev_password@localhost:5433/ai_zalo_db?schema=public

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=chat_messages
QDRANT_VECTOR_SIZE=768

# Ollama (Self-hosted AI) - Requires Ollama running locally or in Docker
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Tool Fallbacks (Optional)
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# OpenAI (GPT-5 Nano for routing/critic)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ROUTER_MODEL=gpt-5-nano

# Langfuse Observability
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Quality Thresholds (CRAG & Critic)
CRITIC_GROUNDEDNESS_THRESHOLD=0.7
CRITIC_HALLUCINATION_THRESHOLD=0.3
CRAG_RELEVANCE_THRESHOLD=0.7
CRAG_MAX_RETRIES=1

# Retrieval Excellence (Phase 3)
COHERE_API_KEY=your_cohere_api_key
COHERE_RERANK_MODEL=rerank-v3.5
RERANK_TOP_N=5
CONTEXT_COMPRESSION_THRESHOLD=1000
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3
